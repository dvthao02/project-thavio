# =====================================================================
# POS MasterV2 — Local Dev Configuration
# Copy file này → .env (đừng commit .env vào git)
# =====================================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=dvthao
POSTGRES_PASSWORD=123
POSTGRES_DB=pos_master
POSTGRES_PORT=5432

# SSL — PRODUCTION: đổi thành require, verify-ca, hoặc verify-full
# LOCAL/Docker: disable vì cả app + DB nằm trong cùng Docker network (không cần mã hóa)
# PGSSLMODE options: disable | allow | prefer | require | verify-ca | verify-full
PGSSLMODE=disable
# PRODUCTION override (uncommment khi deploy):
# PGSSLMODE=require
# PGSSLROOTCERT=/certs/ca.crt

# ── pgAdmin ────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@pos.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# ── Migration runner ───────────────────────────────────────────
# Schema mặc định khi chạy file trong business_base/ + tenant_full_business/
BusinessSchema=business_base

# Dừng khi gặp lỗi (true) hay tiếp tục (false)
STOP_ON_ERROR=true

# Có chạy patch hardening 08_DB_CRITICAL_FIXES.sql sau khi xong tenant migrations không?
APPLY_HARDENING=true
